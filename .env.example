# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored — do NOT commit real credentials.

# ---- Gmail (nodemailer) ----
# The Gmail account that nodemailer authenticates as.
GMAIL_USER=your.address@gmail.com

# 16-character App Password from Google (NOT your regular password).
# How to generate:
#   1. Go to https://myaccount.google.com/security
#   2. Turn on 2-Step Verification if it isn't already
#   3. Go to https://myaccount.google.com/apppasswords
#   4. Create a new app password (label it e.g. "Buddha Skill Academy site")
#   5. Paste the 16-char code below (spaces are fine, nodemailer strips them)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Where enquiries land internally. Can be the same as GMAIL_USER,
# or a shared admissions inbox / distribution list.
ADMISSIONS_EMAIL=info@buddhasskill.com

# Optional — overrides the "From" display name on outgoing emails.
# Defaults to "Buddha's Skill Academy" if not set.
# BRAND_NAME=Buddha's Skill Academy
